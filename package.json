{
  "name": "mesh",
  "version": "0.1.0",
  "description": "Decentralized, privacy-first communication platform",
  "main": "./out/main/index.js",
  "author": "MESH",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:user2": "cross-env MESH_USER_DATA=%TEMP%/mesh-user2 electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "signaling": "tsx src/server/signaling.ts",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.mesh.app",
    "productName": "MESH",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MESH"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.0",
    "emoji-mart": "^5.6.0",
    "express": "^5.2.1",
    "framer-motion": "^11.15.0",
    "libsodium-wrappers": "^0.8.2",
    "lucide-react": "^0.468.0",
    "nat-upnp": "^1.1.1",
    "node-turn": "^0.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.21"
  }
}
